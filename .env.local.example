# Copy this file to .env.local for local development, and set the same vars in
# Vercel → Project → Settings → Environment Variables for production.
#
# Required: your Anthropic API key (server-side secret — never exposed to the browser).
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which Claude model the /api/ai route uses. Defaults to claude-opus-4-8.
# Cheaper/faster options: claude-sonnet-4-6, claude-haiku-4-5
# ANTHROPIC_MODEL=claude-opus-4-8
